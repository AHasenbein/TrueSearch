PORT=8787
MONGODB_URI=mongodb://127.0.0.1:27017/truesearch
GROBID_URL=http://127.0.0.1:8070
CORS_ORIGIN=http://127.0.0.1:5173

# LLM: set at least one. Primary = Google AI Studio (Gemini); on throttle, falls back to OpenRouter if set.
# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-2.0-flash

# https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://github.com/yourname/truesearch
# OPENROUTER_APP_TITLE=TrueSearch

# Metric search + price normalization
DEFAULT_METRIC_SEARCH_LIMIT=12
DEFAULT_WEB_SEARCH_LIMIT=10
PRICE_NORMALIZE_STRICT=false
FX_USD_PER_EUR=1.08
FX_USD_PER_GBP=1.27
FX_USD_PER_JPY=0.0068
FX_USD_PER_CNY=0.14
FX_USD_PER_AUD=0.66
FX_USD_PER_CAD=0.74
FX_USD_PER_INR=0.012
